# PronosPlatform - variables d'environnement
# Copiez ce fichier en .env en local, puis adaptez les valeurs.

# Django
SECRET_KEY=change-me-with-a-long-random-secret-key-of-at-least-50-characters
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de donnees
# En local, si DATABASE_URL est vide, Django utilise db.sqlite3.
# En production, utilisez une URL PostgreSQL fournie par l'hebergeur.
DATABASE_URL=

# Securite / HTTPS
SECURE_SSL_REDIRECT=True
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
CSRF_TRUSTED_ORIGINS=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@pronos-platform.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
